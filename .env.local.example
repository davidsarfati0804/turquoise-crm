# =====================================================
# TURQUOISE CRM - Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git
# =====================================================

# =====================================================
# SUPABASE
# =====================================================
# Get these from https://app.supabase.com/project/_/settings/api

# Public anon key (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# AUTHENTICATION
# =====================================================
# URL de l'application pour les redirections auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# CLAUDE API (Optional - pour futures fonctionnalités IA)
# =====================================================
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =====================================================
# INTEGRATIONS FUTURES (V2+)
# =====================================================

# WhatsApp Business API (V2)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# BRED Payment Gateway (V2)
BRED_API_KEY=
BRED_API_SECRET=
BRED_MERCHANT_ID=

# Pennylane Invoicing (V2)
PENNYLANE_API_KEY=
PENNYLANE_ORGANIZATION_ID=

# =====================================================
# ANALYTICS & MONITORING (Optional)
# =====================================================
# NEXT_PUBLIC_GA_TRACKING_ID=
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# =====================================================
# EMAIL (Optional - pour notifications futures)
# =====================================================
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# =====================================================
# DEVELOPMENT
# =====================================================
NODE_ENV=development
