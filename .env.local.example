# =====================================================
# TURQUOISE CRM - Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git
# =====================================================

# =====================================================
# SUPABASE
# =====================================================
# Get these from https://app.supabase.com/project/_/settings/api

# Public anon key (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# AUTHENTICATION
# =====================================================
# URL de l'application pour les redirections auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# CLAUDE API (Optional - pour futures fonctionnalités IA)
# =====================================================
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# =====================================================
# GOOGLE DOCS API - Template Bulletin d'Inscription
# =====================================================
# Méthode recommandée : OAuth2 (si clés de service account bloquées par l'organisation)
# Créer un OAuth Client ID (type "Application de bureau") sur :
# https://console.cloud.google.com/apis/credentials
# Puis lancer : npx tsx scripts/get-google-refresh-token.ts CLIENT_ID CLIENT_SECRET
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Méthode alternative : Compte de service JSON (si autorisé par votre organisation)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# ID du Google Doc template BI (depuis l'URL du doc)
GOOGLE_DOCS_BI_TEMPLATE_ID=

# (Optionnel) ID du dossier Drive pour stocker les BI générés
GOOGLE_DRIVE_FOLDER_ID=

# =====================================================
# INTEGRATIONS FUTURES (V2+)
# =====================================================

# WhatsApp Business API (V2)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# BRED Payment Gateway (V2)
BRED_API_KEY=
BRED_API_SECRET=
BRED_MERCHANT_ID=

# Pennylane Invoicing (V2)
PENNYLANE_API_KEY=
PENNYLANE_ORGANIZATION_ID=

# =====================================================
# ANALYTICS & MONITORING (Optional)
# =====================================================
# NEXT_PUBLIC_GA_TRACKING_ID=
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# =====================================================
# EMAIL (Optional - pour notifications futures)
# =====================================================
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# =====================================================
# DEVELOPMENT
# =====================================================
NODE_ENV=development
