# =====================================================
# TURQUOISE CRM - Environment Variables
# =====================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git
# =====================================================

# =====================================================
# SUPABASE (REQUIRED)
# =====================================================
# Get these from https://app.supabase.com/project/_/settings/api

# Public URL and anon key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to client, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# AUTHENTICATION
# =====================================================
# URL de l'application pour les redirections auth
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# GOOGLE (REQUIRED FOR BI GENERATION)
# =====================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
GOOGLE_DOCS_BI_TEMPLATE_ID=your-template-id

# =====================================================
# YOUSIGN (REQUIRED FOR ELECTRONIC SIGNATURE)
# =====================================================
YOUSIGN_API_KEY=your-yousign-api-key
YOUSIGN_SANDBOX=true

# =====================================================
# INTEGRATIONS FUTURES (V2+)
# =====================================================

# WhatsApp Business API (V2)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Claude API (Optional - pour futures fonctionnalités IA)
ANTHROPIC_API_KEY=
